ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Exercise-5: OpenAI SDK pointed at Anthropic's OpenAI-compatible endpoint
OPENAI_API_KEY=                                    # same as ANTHROPIC_API_KEY
OPENAI_BASE_URL=https://api.anthropic.com/v1/
AGENT_MODEL=claude-sonnet-4-6
ROUTER_MODEL=claude-haiku-4-5-20251001             # cheap model for routing + memory summarization
SHORT_TERM_TOKEN_LIMIT=8000                        # tokens before memory compaction triggers

# RAG: embeddings use text-embedding-3-small via OpenAI directly (not Anthropic compat endpoint)
# If not set, knowledge search falls back to BM25-only (graceful degradation)
EMBEDDING_API_KEY=                                 # OpenAI API key for text-embedding-3-small

DATABASE_URL=postgresql://helpdesk:helpdesk@localhost:5432/helpdesk
POSTGRES_USER=helpdesk
POSTGRES_PASSWORD=helpdesk
POSTGRES_DB=helpdesk
